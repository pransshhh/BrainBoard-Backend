# Application Settings
NODE_ENV="development" # Environment for the application (e.g., development, production, test)
PORT=3000 # The port the Express server will listen on

# Database Configuration
MONGODB_URI="mongodb://localhost:27017/brainboard_db" # Connection URI for MongoDB

# Security and Authentication
JWT_SECRET="your_jwt_secret_key_here" # Secret key for signing JSON Web Tokens
ACCESS_TOKEN_EXPIRATION="1h" # Expiration time for access tokens (e.g., 1h, 15m)
REFRESH_TOKEN_SECRET="your_refresh_token_secret_key_here" # Secret key for signing refresh tokens
REFRESH_TOKEN_EXPIRATION="7d" # Expiration time for refresh tokens (e.g., 7d, 30d)
CORS_ORIGIN="http://localhost:your_frontend_port" # Allowed origin for CORS requests (e.g., your frontend URL)

# Logging
LOG_LEVEL="info" # The minimum level for application logging (e.g., error, warn, info, debug, verbose, silly)