# Application Configuration
NODE_ENV="development" # The application's environment (e.g., "development", "production", "test")
PORT="3001" # The port on which the Express server will listen
APP_NAME="Brainboard Backend" # The name of the application, used for logging or display

# Database Configuration
DATABASE_URL="your_database_connection_string_here" # Connection string for the application's database

# Security Configuration
JWT_SECRET="your_jwt_secret_key_here" # Secret key for signing and verifying JSON Web Tokens (JWTs)
CORS_ORIGIN="http://localhost:3000" # Comma-separated list of allowed origins for Cross-Origin Resource Sharing (CORS)

# Logging Configuration
LOG_LEVEL="info" # The minimum level of logs to display (e.g., "info", "debug", "warn", "error")